  "intent_ir": {
    "prompt_summary": "A collaborative Kanban board for teams. Users can join workspaces, create projects, manage tasks, comment on tasks, and view activity logs. Admins have full access, members can edit within workspaces, and guests can only view tasks.",
    "extracted_entities": [
      { "name": "Workspace", "type": "Core", "description": "Organizational container for projects and users." },
      { "name": "Project", "type": "Core", "description": "Contains tasks and is associated with a single workspace." },
      { "name": "Task", "type": "Core", "description": "An item of work that belongs to a project and can be assigned to a user." },
      { "name": "Comment", "type": "Supporting", "description": "Feedback left on a task by a user." },
      { "name": "User", "type": "System", "description": "App account with profile details." },
      { "name": "ActivityLog", "type": "Supporting", "description": "Auditable log of state changes for tasks." }
    ],
    "operations": [
      { "name": "create_workspace", "actor": "Admin" },
      { "name": "invite_member", "actor": "Admin" },
      { "name": "create_project", "actor": "Admin, Member" },
      { "name": "manage_tasks", "actor": "Admin, Member", "actions": ["create", "update", "assign", "delete"] },
      { "name": "add_comment", "actor": "Admin, Member", "actions": ["create", "delete_own"] },
      { "name": "view_dashboard", "actor": "Admin, Member, Guest" }
    ],
    "constraints": [
      { "id": "C1", "type": "security", "rule": "Guests cannot write or modify database data" },
      { "id": "C2", "type": "data_integrity", "rule": "Tasks must belong to a project, and projects must belong to a workspace" }
    ]
  },
