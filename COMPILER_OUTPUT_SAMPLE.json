  "authentication_rules": {
    "auth_provider": "JWT",
    "roles": ["Admin", "Member", "Guest"],
    "role_hierarchies": {
      "Admin": ["Member"],
      "Member": ["Guest"],
      "Guest": []
    },
    "endpoint_permissions": [
      { "endpoint_id": "EP_CREATE_WORKSPACE", "allowed_roles": ["Admin"] },
      { "endpoint_id": "EP_GET_TASKS", "allowed_roles": ["Admin", "Member", "Guest"] },
      { "endpoint_id": "EP_CREATE_TASK", "allowed_roles": ["Admin", "Member"] },
      { "endpoint_id": "EP_UPDATE_TASK_STATUS", "allowed_roles": ["Admin", "Member"] }
    ],
    "row_level_security": [
      {
        "table": "tasks",
        "policy": "member_in_workspace",
        "definition": "EXISTS (SELECT 1 FROM workspace_members wm JOIN projects p ON p.workspace_id = wm.workspace_id WHERE p.id = tasks.project_id AND wm.user_id = auth.user_id)"
      }
    ]
  },
  "business_logic_rules": {
    "rules": [
      {
        "id": "RULE_AUTO_LOG_TASK_STATE",
        "event": "tasks.update.status",
        "condition": "old.status != new.status",
        "action": "DB.activity_logs.insert({ task_id: new.id, user_id: auth.user_id, action: 'Status changed from ' + old.status + ' to ' + new.status })"
      },
      {
        "id": "RULE_PREVENT_QA_WITHOUT_PR",
        "event": "tasks.update.status",
        "condition": "new.status == 'QA' && (new.description == null || !new.description.includes('PR:'))",
        "action": "ABORT('A pull request reference (PR: <url>) is required in the description to move task to QA status.')"
      }
    ]
  },
