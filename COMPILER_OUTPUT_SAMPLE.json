          { "name": "description", "label": "Description", "type": "textarea" },
          { "name": "assignee_id", "label": "Assignee", "type": "dropdown", "options_source": "/api/v1/workspace/members" }
        ],
        "actions": {
          "onSubmit": {
            "endpoint_id": "EP_CREATE_TASK",
            "params": {
              "projectId": "state.activeProjectId",
